<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/gradient_background">

    <ImageView
        android:id="@+id/imgMayaLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/maya_logo"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/txtNomeExercicio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nome do exercicio"
        android:textSize="24sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgMayaLogo"
        android:layout_marginTop="16dp"/>

    <ImageView
        android:id="@+id/imgExercicio"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_marginTop="16dp"
        app:srcCompat="?android:attr/galleryItemBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtNomeExercicio"/>

    <ImageView
        android:id="@+id/imgArrowRight"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_marginTop="100dp"
        app:srcCompat="@drawable/outline_arrow_right"
        app:layout_constraintStart_toEndOf="@+id/imgExercicio"
        app:layout_constraintTop_toBottomOf="@+id/txtNomeExercicio" />

    <ImageView
        android:id="@+id/imgArrowLeft"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_marginTop="100dp"
        app:srcCompat="@drawable/outline_arrow_left"
        app:layout_constraintEnd_toStartOf="@+id/imgExercicio"
        app:layout_constraintTop_toBottomOf="@+id/txtNomeExercicio" />

    <ScrollView
        android:id="@+id/scrollObservacao"
        android:layout_width="0dp"
        android:layout_height="150dp"
        android:layout_marginTop="24dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintTop_toBottomOf="@id/imgExercicio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btFinalizarExercicio">

        <TextView
            android:id="@+id/txtObservacao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="observacao"
            android:textAlignment="center"
            android:textSize="18sp"/>

    </ScrollView>

    <Button
        android:id="@+id/btFinalizarExercicio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Finalizar exercício"
        android:layout_marginTop="48dp"
        android:textSize="24sp"
        android:layout_marginStart="100dp"
        android:layout_marginEnd="100dp"
        android:backgroundTint="@color/marrom"
        app:layout_constraintBottom_toTopOf="@+id/btVoltar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btVoltar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Voltar"
        android:textSize="24sp"
        android:layout_marginBottom="24dp"
        android:layout_marginStart="100dp"
        android:layout_marginEnd="100dp"
        android:backgroundTint="@color/azul_escuro"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>


</androidx.constraintlayout.widget.ConstraintLayout>